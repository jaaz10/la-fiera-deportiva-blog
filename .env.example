# Sanity project (create at https://www.sanity.io/manage)
PUBLIC_SANITY_PROJECT_ID=your_project_id
PUBLIC_SANITY_DATASET=production
PUBLIC_SANITY_API_VERSION=2025-03-01

# Optional: needed only if the dataset is private
# SANITY_API_READ_TOKEN=

# Write token (Editor) — used only for `npm run seed:sanity`, never commit this
# SANITY_API_WRITE_TOKEN=

# Studio (same values; used when running `npm run studio`)
SANITY_STUDIO_PROJECT_ID=your_project_id
SANITY_STUDIO_DATASET=production
