---
import Layout from "../layouts/Layout.astro";
import { formatPublishedDate, getVideoThumbnailUrl } from "../lib/sanity";
import type { Video } from "../lib/types";

interface Props {
  video: Video;
  related?: Video[];
}

const { video, related = [] } = Astro.props;
const embedUrl = `https://www.youtube.com/embed/${video.youtubeId}`;
const pageTitle = `${video.title} | La Fiera Deportiva`;
---

<Layout title={pageTitle} description={video.description}>
  <div class="article-header">
    <div class="category-tag">{video.category}</div>
    <h1 class="article-title">{video.title}</h1>
    <p class="article-excerpt">{video.description}</p>
    <p class="article-date">{formatPublishedDate(video.publishedAt)}</p>
  </div>

  <section class="featured-video">
    <div class="container">
      <div class="video-player-container">
        <div class="video-player">
          <iframe
            width="100%"
            height="100%"
            src={embedUrl}
            title={video.title}
            frameborder="0"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen
          >
          </iframe>
        </div>
      </div>

      <div class="video-content">
        <div class="video-description">
          <h2>Descripción</h2>
          <p>{video.description}</p>
        </div>
      </div>

      <div class="article-sidebar">
        <div class="sidebar-section">
          <h3 class="sidebar-title">Videos Relacionados</h3>
          <div class="related-videos">
            {
              related.map((item) => (
                <a href={`/videos/${item.slug}`} class="related-video">
                  <img src={getVideoThumbnailUrl(item)} alt={item.title} />
                  <div class="related-video-title">{item.title}</div>
                </a>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  .article-header {
    background-color: #1c2b5a;
    padding: 1.5rem 0 3rem;
    text-align: center;
    width: 100%;
  }

  .category-tag {
    display: inline-block;
    background-color: #e24b32;
    color: white;
    padding: 0.4rem 1rem;
    border-radius: 4px;
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 2rem;
  }

  .article-title {
    font-size: 2.8rem;
    line-height: 1.2;
    font-weight: 800;
    color: white;
    margin: 0 auto 1.5rem;
    max-width: 1200px;
    padding: 0 1.5rem;
    text-shadow: 0 2px 4px rgba(0, 0, 0, 0.3);
  }

  .article-excerpt {
    font-size: 1.4rem;
    color: #e6e6e6;
    font-weight: 400;
    margin: 0 auto 0.5rem;
    max-width: 900px;
    padding: 0 1.5rem;
    line-height: 1.4;
  }

  .article-date {
    color: #a0a0a0;
    font-size: 0.95rem;
    margin: 0.5rem auto 0;
    max-width: 900px;
    padding: 0 1.5rem;
  }

  .featured-video {
    padding: 2rem 0 4rem;
  }

  .container {
    max-width: 1240px;
    margin: 0 auto;
    padding: 0 1.5rem;
    display: grid;
    grid-template-columns: 1fr 350px;
    grid-template-areas:
      "player player"
      "content sidebar";
    gap: 2rem;
  }

  .video-player-container {
    grid-area: player;
    width: 100%;
    margin-bottom: 2rem;
    border-radius: 8px;
    overflow: hidden;
    background-color: #000;
  }

  .video-player {
    position: relative;
    padding-top: 56.25%;
    width: 100%;
  }

  .video-player iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-content {
    grid-area: content;
    color: white;
  }

  .video-description h2 {
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
    color: white;
  }

  .video-description p {
    font-size: 1.1rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .article-sidebar {
    grid-area: sidebar;
  }

  .sidebar-section {
    background-color: #1c2b5a;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .sidebar-title {
    font-size: 1.2rem;
    font-weight: 700;
    color: white;
    margin: 0 0 1rem;
  }

  .related-videos {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .related-video {
    display: flex;
    gap: 0.75rem;
    text-decoration: none;
  }

  .related-video img {
    width: 100px;
    height: 60px;
    object-fit: cover;
    border-radius: 4px;
  }

  .related-video-title {
    font-size: 0.9rem;
    font-weight: 500;
    line-height: 1.3;
    color: white;
  }

  @media (max-width: 992px) {
    .container {
      grid-template-columns: 1fr;
      grid-template-areas:
        "player"
        "content"
        "sidebar";
    }

    .article-title {
      font-size: 2.2rem;
    }

    .article-excerpt {
      font-size: 1.2rem;
    }
  }

  @media (max-width: 576px) {
    .article-title {
      font-size: 1.8rem;
    }

    .article-excerpt {
      font-size: 1.1rem;
    }

    .related-video {
      flex-direction: column;
      gap: 0.5rem;
    }

    .related-video img {
      width: 100%;
      height: 120px;
    }
  }
</style>
