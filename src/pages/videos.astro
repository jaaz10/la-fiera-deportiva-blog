---
import Layout from "../layouts/Layout.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getVideos, getVideoThumbnailUrl } from "../lib/sanity";

const videos = await getVideos();
---

<Layout title={`Videos | ${SITE_TITLE}`} description={SITE_DESCRIPTION}>
  <section class="videos-page">
    <div class="container">
      <h1 class="page-title">Recent Videos</h1>
      <div class="grid grid-3">
        {
          videos.map((video) => (
            <div class="content-card">
              <a href={`/videos/${video.slug}`}>
                <div class="card-thumbnail">
                  <img
                    src={getVideoThumbnailUrl(video)}
                    alt={video.title}
                  />
                  <div class="icon-play">
                    <i class="fas fa-play-circle"></i>
                  </div>
                </div>
                <div class="card-body">
                  <h3>{video.title}</h3>
                  <div class="card-meta">
                    <span class="card-meta-item">
                      <i class="fa-solid fa-video"></i> {video.category}
                    </span>
                  </div>
                </div>
              </a>
            </div>
          ))
        }
      </div>
    </div>
  </section>
</Layout>

<style>
  .videos-page {
    padding: 5rem 0;
  }

  .page-title {
    font-size: 2.5rem;
    margin-bottom: 3rem;
    font-weight: 800;
  }
</style>
